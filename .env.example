# PostgreSQL — Supabase
# DATABASE_URL / NEXT_DATABASE_URL: Direct connection (db.xxx.supabase.co:5432)
# FLASK_DATABASE_URL: Transaction pooler (pooler.supabase.com:6543)

DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.TU_PROJECT_REF.supabase.co:5432/postgres"
NEXT_DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.TU_PROJECT_REF.supabase.co:5432/postgres"
FLASK_DATABASE_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"
FLASK_APP_URL="http://localhost:5001"

# Flask
SECRET_KEY=""   # Generar con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_DEBUG="true"
PORT="5001"

# ─── Integración NetSuite (Cargos STR) ───────────────────────────────────────
# Los VALORES reales se cargan en Vercel (Settings → Environment Variables),
# NUNCA en este repo ni en el chat. Solo nombres/placeholders acá.
# Cambiar a "real" activa el cliente con auth TBA/OAuth1; "mock" usa el simulado.
NETSUITE_MODE="mock"
# Cuenta 8312907 (producción) — defaults en código, overridables aquí:
# NETSUITE_BASE_URL="https://8312907.suitetalk.api.netsuite.com"  # host REST
# NETSUITE_ACCOUNT_ID="8312907"            # realm OAuth (= accountId en producción)
# NETSUITE_RECORD_PATH="/services/rest/record/v1/purchaseOrder"  # registro de la OC
# Purchase Order — IDs internos fijos de la cuenta (entity = vendor sale del OR).
# Defaults en código: subsidiary=2, item=488, quantity=1 (location NO se envía).
# NETSUITE_SUBSIDIARY_ID="2"               # internalId de la subsidiaria
# NETSUITE_LOCATION_ID=""                  # opcional: solo si la transacción lo requiere
# NETSUITE_ITEM_ID="488"                   # internalId del ítem de la línea
# NETSUITE_DEFAULT_QUANTITY="1"            # cantidad de la línea (número)
# NETSUITE_CONSUMER_KEY=""                 # secret — solo en Vercel
# NETSUITE_CONSUMER_SECRET=""              # secret — solo en Vercel
# NETSUITE_TOKEN_ID=""                     # secret — solo en Vercel
# NETSUITE_TOKEN_SECRET=""                 # secret — solo en Vercel
